#include <stdio.h>

void Bubble_sort_Otimizado(int V[], int n){
    int trocas = 0;
    int comparacoes = 0;
    int early;

    // Flag usada para evitar comparações desnecessárias quando o vetor já está ordenado.
    // Isso melhora o melhor caso para O(n), pois o algoritmo faz apenas uma única varredura, ao notar que não houve trocas, interrompe a execução.

    for (int i = 0; i < n - 1; i++){
        early = 0;
        for (int j = 0; j < n - i - 1; j++){
            comparacoes++;
            if (V[j] > V[j + 1]){
                int temp = V[j];
                V[j] = V[j + 1];
                V[j + 1] = temp;
                trocas++;
                early = 1;
            }
        }
        if (!early)
            break;
    }
    printf("\nEstatisticas: %d comparacoes e %d trocas.\n", comparacoes, trocas);
}

void imprimirVetor(int V[], int n){
    printf("[ ");
    for (int i = 0; i < n; i++) printf("%d ", V[i]);
    printf("]\n");
}

int main(){
    int meuVetor[] = {64, 34, 25, 12, 22, 11, 90};
    int n = 7;
    
    printf("Vetor original: ");
    imprimirVetor(meuVetor, n);
    
    Bubble_sort_Otimizado(meuVetor, n);
    
    printf("Vetor ordenado: ");
    imprimirVetor(meuVetor, n);

    return 0;
}
